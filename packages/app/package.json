{
  "name": "app",
  "version": "0.0.0",
  "private": true,
  "bundled": true,
  "backstage": {
    "role": "frontend"
  },
  "dependencies": {
    "@backstage/app-defaults": "^1.7.9",
    "@backstage/cli": "^0.36.3",
    "@backstage/core-app-api": "^1.20.2",
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/integration-react": "^1.2.19",
    "@backstage/plugin-catalog": "^2.0.6",
    "@backstage/plugin-permission-react": "^0.5.2",
    "@backstage/plugin-user-settings": "^0.9.4",
    "@backstage/theme": "^0.7.3",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@kpt/backstage-plugin-cad": "*",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "history": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.30.0",
    "react-router-dom": "^6.30.0",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@backstage/test-utils": "^1.7.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react-dom": "*",
    "cross-env": "^10.1.0",
    "cypress": "^13.0.0",
    "eslint-plugin-cypress": "^4.0.0",
    "start-server-and-test": "^3.0.10"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "test": "backstage-cli package test",
    "lint": "backstage-cli package lint",
    "test:e2e": "cross-env PORT=3001 start-server-and-test start http://localhost:3001 cy:dev",
    "test:e2e:ci": "cross-env PORT=3001 start-server-and-test start http://localhost:3001 cy:run",
    "cy:dev": "cypress open",
    "cy:run": "cypress run"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "files": [
    "dist"
  ],
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/setupTests.ts",
      "@testing-library/jest-dom"
    ]
  }
}
