{
  "name": "kpt-backstage-plugins",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.20.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"yarn start\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build": "backstage-cli repo build --all",
    "build-image": "docker build --target backstage-app --tag kpt-backstage-plugins .",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli clean && lerna run clean",
    "diff": "lerna run diff --",
    "test": "backstage-cli test",
    "test:all": "lerna run test -- --coverage",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "create-plugin": "backstage-cli create-plugin --scope internal",
    "remove-plugin": "backstage-cli remove-plugin"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@babel/preset-typescript": "^8.0.1",
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@jest/environment-jsdom-abstract": "^30",
    "@spotify/prettier-config": "^15.0.0",
    "@types/jest": "^30",
    "concurrently": "^10.0.3",
    "jest": "^30",
    "jsdom": "^29",
    "lerna": "^9.0.7",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@backstage/backend-common/@kubernetes/client-node": "^1.4.0",
    "@kubernetes/client-node": "^1.4.0",
    "@backstage/core-components": "^0.18.11",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.18.1",
    "@types/webpack-env": "^1.18.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/../../../jest.setup.js",
      "@testing-library/jest-dom"
    ],
    "moduleNameMapper": {
      "^monaco-editor$": "<rootDir>/../../../__mocks__/monaco-editor.ts"
    }
  },
  "dependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0"
  }
}
