{
  "name": "kpt-backstage-plugins",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"yarn start\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build": "backstage-cli repo build --all",
    "build-image": "docker build --target backstage-app --tag kpt-backstage-plugins .",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "create-plugin": "backstage-cli create-plugin --scope internal",
    "remove-plugin": "backstage-cli remove-plugin"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^monaco-editor$": "<rootDir>/__mocks__/monaco-editor.ts",
      "^monaco-editor/(.*)$": "<rootDir>/__mocks__/monaco-editor.ts",
      "^@monaco-editor/react$": "<rootDir>/__mocks__/@monaco-editor/react.js"
    }
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@jest/environment-jsdom-abstract": "^30.4.1",
    "@spotify/prettier-config": "^15.0.0",
    "@testing-library/dom": "^10.4.1",
    "concurrently": "^9.0.0",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react-router": "^6.30.0",
    "react-router-dom": "^6.30.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  }
}
